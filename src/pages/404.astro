---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="数字游民部落"
  description="A minimalist Astro starter for personal blogs."
  author="数字游民Jarod"
  url=""
>
  <meta name="robots" content="noindex" slot="after-header" />
  <h1 class="heading text-center">404</h1>
  <p class="paragraph text-center">The page you requested cannot be found!</p>

  <script>
    import { track } from '@vercel/analytics';
    
    // As soon as the 404 page loads, send a custom event with the broken URL
    // This allows us to see exactly *which* URLs are 404ing in the Analytics Dashboard
    window.addEventListener('load', () => {
      track('404_error', {
        path: window.location.pathname,
        url: window.location.href,
        referrer: document.referrer || 'direct'
      });
    });
  </script>
</BaseLayout>
